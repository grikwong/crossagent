#!/usr/bin/env bash
set -euo pipefail

# ============================================================================
# crossagent — Cross-Model AI Agent Orchestrator
# Leverages Claude Code (planner/implementer) + Codex CLI (reviewer/verifier)
# ============================================================================

CROSSAGENT_VERSION="1.0.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CROSSAGENT_HOME="${CROSSAGENT_HOME:-$HOME/.crossagent}"
WORKFLOWS_DIR="$CROSSAGENT_HOME/workflows"
AGENTS_DIR="$CROSSAGENT_HOME/agents"

# ── Colors & Symbols ────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

PHASE_COLORS=( '' "$BLUE" "$MAGENTA" "$CYAN" "$GREEN" )
PHASE_LABELS=( '' 'PLAN' 'REVIEW' 'IMPLEMENT' 'VERIFY' )
# ── UI Helpers ──────────────────────────────────────────────────────────────

info()    { echo -e "  ${BLUE}i${NC} $*"; }
success() { echo -e "  ${GREEN}✓${NC} $*"; }
warn()    { echo -e "  ${YELLOW}!${NC} $*"; }
die()     { echo -e "  ${RED}✗${NC} $*" >&2; exit 1; }

separator() { echo -e "  ${DIM}$(printf '%.0s─' {1..50})${NC}"; }

phase_banner() {
    local p=$1 name=$2 tool=$3
    local c="${PHASE_COLORS[$p]}" label="${PHASE_LABELS[$p]}"
    echo ""
    echo -e "  ${c}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "  ${BOLD}PHASE ${p}: ${label}${NC}"
    echo -e "  ${DIM}Tool:${NC}     ${tool}"
    echo -e "  ${DIM}Workflow:${NC} ${name}"
    echo -e "  ${c}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

# ── State Management ────────────────────────────────────────────────────────

MEMORY_DIR="$CROSSAGENT_HOME/memory"

ensure_dirs() {
    mkdir -p "$CROSSAGENT_HOME" "$WORKFLOWS_DIR" "$AGENTS_DIR" "$MEMORY_DIR"
    init_global_memory
}

# ── Memory Functions ───────────────────────────────────────────────────────

init_global_memory() {
    if [[ ! -f "$MEMORY_DIR/global-context.md" ]]; then
        cat > "$MEMORY_DIR/global-context.md" <<'EOF'
# Crossagent Global Context

> Cross-workflow patterns, conventions, and accumulated knowledge.
> Updated by agents after each workflow phase.

---

## Codebase Patterns

(Patterns discovered across workflows will be added here)

## Conventions

(Coding conventions, naming patterns, etc.)

## Changelog

| Date | Change | Source Workflow |
|------|--------|----------------|
