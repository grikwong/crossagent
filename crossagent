init_workflow_memory() {
    local d=$1 name=$2 desc=$3 repo=$4
    [[ -f "$d/memory.md" ]] && return 0
    cat > "$d/memory.md" <<EOF
# Workflow Memory: ${name}

## Metadata
| Field | Value |
|-------|-------|
