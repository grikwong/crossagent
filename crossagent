cmd_new() {
    local name="" repo="" add_dirs=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --repo)
                require_option_arg "$1" "${2:-}"
                repo="$2"
                shift 2
                ;;
            --add-dir)
                require_option_arg "$1" "${2:-}"
                local resolved_add_dir
                resolved_add_dir=$(resolve_dir "Additional directory" "$2")
                add_dirs="${add_dirs:+${add_dirs},}${resolved_add_dir}"
                shift 2
                ;;
            -h|--help)   echo "Usage: crossagent new <name> [--repo <path>] [--add-dir <path>]..."; exit 0 ;;
            -*)          die "Unknown option: $1" ;;
            *)           name="$1"; shift ;;
        esac
    done

    [[ -z "$name" ]] && die "Usage: crossagent new <name> [--repo <path>] [--add-dir <path>]..."

    # Sanitize
    name=$(echo "$name" | tr ' ' '-' | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]//g')
    [[ -z "$name" ]] && die "Invalid workflow name after sanitization."

    ensure_dirs
    local d="$WORKFLOWS_DIR/$name"
    [[ -d "$d" ]] && die "Workflow '${name}' already exists. Use ${BOLD}crossagent use ${name}${NC} to switch to it."

    mkdir -p "$d/prompts"

    # Default repo to cwd
    repo="${repo:-$(pwd)}"
    repo=$(resolve_dir "Repository" "$repo")

    set_conf "$d" "repo" "$repo"
    set_conf "$d" "add_dirs" "$add_dirs"
    set_conf "$d" "created" "$(date '+%Y-%m-%d %H:%M')"

    echo ""
    echo -e "  ${BOLD}New Workflow: ${name}${NC}"
    separator
    echo -e "  ${DIM}Repository:${NC} $repo"
    [[ -n "$add_dirs" ]] && echo -e "  ${DIM}Extra dirs:${NC} $add_dirs"
    echo ""

    # Read description
    if [[ -t 0 ]]; then
        echo -e "  Describe the feature/task ${DIM}(empty line to finish):${NC}"
        echo ""
        local desc="" line
        while IFS= read -r -p "  > " line; do
            [[ -z "$line" && -n "$desc" ]] && break
            desc="${desc}${desc:+$'\n'}${line}"
        done
    else
        local desc
        desc=$(cat)
    fi

    [[ -z "$desc" ]] && { rm -rf "$d"; die "Description cannot be empty."; }

    echo "$desc" > "$d/description"
    set_phase "$d" "1"
    set_current "$name"
    init_workflow_memory "$d" "$name" "$desc" "$repo"

    echo ""
    success "Workflow '${name}' created"
    success "Current phase: ${BOLD}1 — Plan${NC}"
    echo ""
    echo -e "  Next: ${BOLD}crossagent plan${NC}"
    echo ""
}

