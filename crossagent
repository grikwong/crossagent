# ── Verdict Parsing ─────────────────────────────────────────────────────────

# Parse verify.md and return a structured verdict.
# Outputs lines: verdict=<pass|fix|rework|unknown>, status=<text>, recommendation=<text>
judge_verify() {
    local verify_file="$1"
    [[ -f "$verify_file" ]] || { echo "verdict=missing"; return 1; }

    local status_val="" rec_val="" verdict
    local in_status=false in_rec=false

    # Read verify.md line by line.  When we hit a "Status" or
    # "Recommendation" heading, capture the first non-empty line after it.
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Detect section headers
        if echo "$line" | grep -qi '^#\{1,4\}[[:space:]]*status'; then
            in_status=true; in_rec=false; continue
        fi
        if echo "$line" | grep -qi '^#\{1,4\}[[:space:]]*recommendation'; then
            in_rec=true; in_status=false; continue
        fi

        # Capture first non-empty line after header
        local stripped
        stripped=$(echo "$line" | sed 's/^[[:space:]]*//')
        [[ -z "$stripped" ]] && continue

        if $in_status; then
            status_val=$(echo "$stripped" | sed 's/\*//g')
            in_status=false
        fi
        if $in_rec; then
            rec_val=$(echo "$stripped" | sed 's/\*//g')
            in_rec=false
        fi
    done < "$verify_file"

    # Determine verdict from recommendation (primary) then status (fallback)
    local combined
    combined=$(echo "$rec_val $status_val" | tr '[:upper:]' '[:lower:]')

    if echo "$combined" | grep -qi 'ship it'; then
        verdict="pass"
    elif echo "$combined" | grep -qi 'needs rework'; then
        verdict="rework"
    elif echo "$combined" | grep -qi 'fix issues'; then
        verdict="fix"
    elif echo "$combined" | grep -qi 'pass'; then
        verdict="pass"
    elif echo "$combined" | grep -qi 'fail'; then
        verdict="fix"
    else
        verdict="unknown"
    fi

    echo "verdict=${verdict}"
    echo "status=${status_val}"
    echo "recommendation=${rec_val}"
}

# Parse review.md and return a structured verdict.
# Review format has: ### Verdict — APPROVE | APPROVE WITH CHANGES | REQUEST REWORK
judge_review() {
    local review_file="$1"
    [[ -f "$review_file" ]] || { echo "verdict=missing"; return 1; }

    local verdict_val="" verdict
    local in_verdict=false

    while IFS= read -r line || [[ -n "$line" ]]; do
        if echo "$line" | grep -qi '^#\{1,4\}[[:space:]]*verdict'; then
            in_verdict=true; continue
        fi

        local stripped
        stripped=$(echo "$line" | sed 's/^[[:space:]]*//')
        [[ -z "$stripped" ]] && continue

        if $in_verdict; then
            verdict_val=$(echo "$stripped" | sed 's/\*//g')
            in_verdict=false
        fi
    done < "$review_file"

    local combined
    combined=$(echo "$verdict_val" | tr '[:upper:]' '[:lower:]')

    if echo "$combined" | grep -qi 'request rework'; then
        verdict="rework"
    elif echo "$combined" | grep -qi 'approve with changes'; then
        verdict="approve_with_changes"
    elif echo "$combined" | grep -qi 'approve'; then
        verdict="approve"
    else
        verdict="unknown"
    fi

    echo "verdict=${verdict}"
    echo "review_verdict=${verdict_val}"
}

