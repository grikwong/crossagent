  "repo": "$(json_escape "$repo")",
  "add_dirs": $(_json_csv_to_array "$add_dirs"),
  "repos": {"primary":"$(json_escape "$repo")","additional":$(_json_csv_to_array "$add_dirs")},
  "description": "$(json_escape "$desc")",
  "created": "$(json_escape "$created")",
  "workflow_dir": "$(json_escape "$d")",
  "agents": {
    "plan": {"name":"$(json_escape "$plan_agent")","display_name":"$(json_escape "$(get_agent_prop "$plan_agent" "display_name")")"},
    "review": {"name":"$(json_escape "$review_agent")","display_name":"$(json_escape "$(get_agent_prop "$review_agent" "display_name")")"},
    "implement": {"name":"$(json_escape "$implement_agent")","display_name":"$(json_escape "$(get_agent_prop "$implement_agent" "display_name")")"},
    "verify": {"name":"$(json_escape "$verify_agent")","display_name":"$(json_escape "$(get_agent_prop "$verify_agent" "display_name")")"}
  },
  "retry_count": ${retry_count},
  "max_retries": ${max_retries},
  "artifacts": {
    "plan": $(_json_artifact "$d/plan.md"),
    "review": $(_json_artifact "$d/review.md"),
    "implement": $(_json_artifact "$d/implement.md"),
    "verify": $(_json_artifact "$d/verify.md"),
    "memory": $(_json_artifact "$d/memory.md")
  }
}
EJSON
        return 0
    fi

    echo ""
    echo -e "  ${BOLD}Workflow: ${name}${NC}"
    separator
    echo -e "  ${DIM}Created:${NC}     ${created}"
    echo -e "  ${DIM}Repository:${NC}  ${repo}"
    [[ -n "$add_dirs" ]] && echo -e "  ${DIM}Extra dirs:${NC}  ${add_dirs}"
    echo -e "  ${DIM}Agents:${NC}      plan=${plan_agent}, review=${review_agent}, implement=${implement_agent}, verify=${verify_agent}"
    echo -e "  ${DIM}Description:${NC}"
    echo "$desc" | sed 's/^/    /'
    echo ""

    local i label icon extra
    for i in 1 2 3 4; do
        label="${PHASE_LABELS[$i]}"
        extra=""

        if [[ "$pn" -gt "$i" ]]; then
            icon="${GREEN}✓${NC}"
        elif [[ "$pn" -eq "$i" ]]; then
            icon="${YELLOW}→${NC}"
        else
            icon="${DIM}○${NC}"
        fi

        case $i in
            1) [[ -f "$d/plan.md" ]]   && extra=" ${DIM}($(wc -l < "$d/plan.md" | tr -d ' ') lines)${NC}" ;;
            2) [[ -f "$d/review.md" ]]  && extra=" ${DIM}($(wc -l < "$d/review.md" | tr -d ' ') lines)${NC}" ;;
            4) [[ -f "$d/verify.md" ]]  && extra=" ${DIM}($(wc -l < "$d/verify.md" | tr -d ' ') lines)${NC}" ;;
        esac

        printf "  %b Phase %d: %-12s%b\n" "$icon" "$i" "$label" "$extra"
    done
    echo ""

    if [[ "$phase" == "done" ]]; then
        echo -e "  ${GREEN}${BOLD}Workflow complete${NC}"
    else
        local cmds=( '' 'plan' 'review' 'implement' 'verify' )
        echo -e "  Next: ${BOLD}crossagent ${cmds[$phase]}${NC}"
    fi
    echo ""
}

cmd_list() {
    local json_mode=false
    [[ "${1:-}" == "--json" ]] && json_mode=true

    ensure_dirs
    local current
    current=$(get_current)

    if $json_mode; then
        local items="" first=true
        for dir in "$WORKFLOWS_DIR"/*/; do
            [[ -d "$dir" ]] || continue
            local wname wphase wlabel active_flag
            wname=$(basename "$dir")
            wphase=$(get_phase "$dir")
            if [[ "$wphase" == "done" ]]; then
                wlabel="done"
            else
                wlabel=$(echo "${PHASE_LABELS[$wphase]}" | tr '[:upper:]' '[:lower:]')
            fi
            active_flag=false
            [[ "$wname" == "$current" ]] && active_flag=true
            $first || items+=","
            items+="{\"name\":\"$(json_escape "$wname")\",\"phase\":\"$wphase\",\"phase_label\":\"$wlabel\",\"active\":$active_flag,\"agents\":{\"plan\":\"$(json_escape "$(get_phase_agent "$dir" plan)")\",\"review\":\"$(json_escape "$(get_phase_agent "$dir" review)")\",\"implement\":\"$(json_escape "$(get_phase_agent "$dir" implement)")\",\"verify\":\"$(json_escape "$(get_phase_agent "$dir" verify)")\"}}"
            first=false
        done
        echo "{\"workflows\":[${items}],\"active\":\"$(json_escape "$current")\"}"
        return 0
    fi

    echo ""
    echo -e "  ${BOLD}Workflows${NC}"
    separator

    local count=0
    for dir in "$WORKFLOWS_DIR"/*/; do
        [[ -d "$dir" ]] || continue
        local wname wphase indicator=""
        wname=$(basename "$dir")
        wphase=$(get_phase "$dir")
        [[ "$wname" == "$current" ]] && indicator=" ${CYAN}(active)${NC}"

        local phase_display
        if [[ "$wphase" == "done" ]]; then
            phase_display="${GREEN}complete${NC}"
        else
            phase_display="phase ${wphase} — $(echo "${PHASE_LABELS[$wphase]}" | tr '[:upper:]' '[:lower:]')"
        fi

        echo -e "  ${BOLD}${wname}${NC} — ${phase_display}${indicator}"
        echo -e "    ${DIM}agents:${NC} plan=$(get_phase_agent "$dir" plan), review=$(get_phase_agent "$dir" review), implement=$(get_phase_agent "$dir" implement), verify=$(get_phase_agent "$dir" verify)"
        ((count++)) || true
    done

    [[ $count -eq 0 ]] && echo -e "  ${DIM}No workflows yet.${NC}"
    echo ""
}

cmd_agents() {
    local subcmd="${1:-list}"
    shift 2>/dev/null || true

    case "$subcmd" in
        list)
            local json_mode=false
            [[ "${1:-}" == "--json" ]] && json_mode=true
            ensure_dirs

            if $json_mode; then
                local items="" first=true
                local builtin
                for builtin in claude codex; do
                    $first || items+=","
                    items+="{\"name\":\"$builtin\",\"display_name\":\"$(json_escape "$(get_agent_prop "$builtin" "display_name")")\",\"adapter\":\"$(get_agent_prop "$builtin" "adapter")\",\"command\":\"$(get_agent_prop "$builtin" "command")\",\"builtin\":true}"
                    first=false
                done

                local file name adapter command display
                for file in "$AGENTS_DIR"/*; do
                    [[ -f "$file" ]] || continue
                    name=$(basename "$file")
                    adapter=$(get_agent_prop "$name" "adapter")
                    command=$(get_agent_prop "$name" "command")
                    display=$(get_agent_prop "$name" "display_name")
                    $first || items+=","
                    items+="{\"name\":\"$(json_escape "$name")\",\"display_name\":\"$(json_escape "$display")\",\"adapter\":\"$(json_escape "$adapter")\",\"command\":\"$(json_escape "$command")\",\"builtin\":false}"
                    first=false
                done

                echo "{\"agents\":[${items}]}"
                return 0
            fi

            echo ""
            echo -e "  ${BOLD}Agents${NC}"
            separator
            echo -e "  ${BOLD}claude${NC} — $(get_agent_prop claude display_name) ${DIM}[builtin | adapter=claude | command=claude]${NC}"
            echo -e "  ${BOLD}codex${NC} — $(get_agent_prop codex display_name) ${DIM}[builtin | adapter=codex | command=codex]${NC}"
            local file name adapter command display
            for file in "$AGENTS_DIR"/*; do
                [[ -f "$file" ]] || continue
                name=$(basename "$file")
                adapter=$(get_agent_prop "$name" "adapter")
                command=$(get_agent_prop "$name" "command")
                display=$(get_agent_prop "$name" "display_name")
                echo -e "  ${BOLD}${name}${NC} — ${display} ${DIM}[custom | adapter=${adapter} | command=${command}]${NC}"
            done
            echo ""
            ;;

        add)
            ensure_dirs
            local name="${1:-}" adapter="" command="" display=""
            [[ -n "$name" ]] || die "Usage: crossagent agents add <name> --adapter <claude|codex> [--command <cmd>] [--display-name <name>]"
            shift
            name=$(sanitize_agent_name "$name")
            [[ -n "$name" ]] || die "Invalid agent name."
            agent_is_builtin "$name" && die "Cannot overwrite builtin agent '${name}'."
            [[ ! -f "$(agent_file "$name")" ]] || die "Agent already exists: ${name}"

            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --adapter) require_option_arg "$1" "${2:-}"; adapter="$2"; shift 2 ;;
                    --command) require_option_arg "$1" "${2:-}"; command="$2"; shift 2 ;;
                    --display-name) require_option_arg "$1" "${2:-}"; display="$2"; shift 2 ;;
                    -*) die "Unknown option: $1" ;;
                    *) die "Unexpected argument: $1" ;;
                esac
            done

            [[ "$adapter" == "claude" || "$adapter" == "codex" ]] || die "Agent adapter must be one of: claude, codex"
            command="${command:-$adapter}"
            display="${display:-$name}"

            cat > "$(agent_file "$name")" <<EOF
adapter=${adapter}
command=${command}
display_name=${display}
EOF
            success "Agent '${name}' added."
            ;;

        remove|rm|delete)
            ensure_dirs
            local name="${1:-}"
            [[ -n "$name" ]] || die "Usage: crossagent agents remove <name>"
            agent_is_builtin "$name" && die "Cannot remove builtin agent '${name}'."
            local file
            file=$(agent_file "$name")
            [[ -f "$file" ]] || die "Agent not found: ${name}"

            local dir key
            for dir in "$WORKFLOWS_DIR"/*; do
                [[ -d "$dir" ]] || continue
                for key in plan review implement verify; do
                    [[ "$(get_phase_agent "$dir" "$key")" == "$name" ]] && die "Agent '${name}' is assigned to workflow '$(basename "$dir")' phase '${key}'. Reassign it first."
                done
            done

            rm -f "$file"
            success "Agent '${name}' removed."
            ;;

        show|assignments)
            local json_mode=false workflow=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --json) json_mode=true; shift ;;
                    --workflow) require_option_arg "$1" "${2:-}"; workflow="$2"; shift 2 ;;
                    -*) die "Unknown option: $1" ;;
                    *) die "Unexpected argument: $1" ;;
                esac
            done
            [[ -n "$workflow" ]] || workflow=$(require_workflow)
            local d="$WORKFLOWS_DIR/$workflow"
            [[ -d "$d" ]] || die "Workflow '${workflow}' not found."
            local plan_agent review_agent implement_agent verify_agent
            plan_agent=$(get_phase_agent "$d" plan)
            review_agent=$(get_phase_agent "$d" review)
            implement_agent=$(get_phase_agent "$d" implement)
            verify_agent=$(get_phase_agent "$d" verify)

            if $json_mode; then
                cat <<EJSON
{"workflow":"$(json_escape "$workflow")","agents":{"plan":"$(json_escape "$plan_agent")","review":"$(json_escape "$review_agent")","implement":"$(json_escape "$implement_agent")","verify":"$(json_escape "$verify_agent")"}}
EJSON
                return 0
            fi

            echo ""
            echo -e "  ${BOLD}Workflow Agents: ${workflow}${NC}"
            separator
            echo -e "  plan:      ${plan_agent} ${DIM}($(get_agent_prop "$plan_agent" "display_name"))${NC}"
            echo -e "  review:    ${review_agent} ${DIM}($(get_agent_prop "$review_agent" "display_name"))${NC}"
            echo -e "  implement: ${implement_agent} ${DIM}($(get_agent_prop "$implement_agent" "display_name"))${NC}"
            echo -e "  verify:    ${verify_agent} ${DIM}($(get_agent_prop "$verify_agent" "display_name"))${NC}"
            echo ""
            ;;

        assign)
            local phase="${1:-}" agent="${2:-}" workflow=""
            [[ -n "$phase" && -n "$agent" ]] || die "Usage: crossagent agents assign <plan|review|implement|verify> <agent> [--workflow <name>]"
            shift 2
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --workflow) require_option_arg "$1" "${2:-}"; workflow="$2"; shift 2 ;;
                    -*) die "Unknown option: $1" ;;
                    *) die "Unexpected argument: $1" ;;
                esac
            done

            phase=$(phase_key "$phase") || die "Unknown phase: ${phase}"
            [[ -n "$workflow" ]] || workflow=$(require_workflow)
            local d="$WORKFLOWS_DIR/$workflow"
            [[ -d "$d" ]] || die "Workflow '${workflow}' not found."
            set_phase_agent "$d" "$phase" "$agent"
            success "Assigned agent '${agent}' to ${phase} for workflow '${workflow}'."
            ;;

        reset)
            local phase="${1:-}" workflow=""
            [[ -n "$phase" ]] || die "Usage: crossagent agents reset <plan|review|implement|verify> [--workflow <name>]"
            shift
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --workflow) require_option_arg "$1" "${2:-}"; workflow="$2"; shift 2 ;;
                    -*) die "Unknown option: $1" ;;
                    *) die "Unexpected argument: $1" ;;
                esac
            done

            phase=$(phase_key "$phase") || die "Unknown phase: ${phase}"
            [[ -n "$workflow" ]] || workflow=$(require_workflow)
            local d="$WORKFLOWS_DIR/$workflow"
            [[ -d "$d" ]] || die "Workflow '${workflow}' not found."
            reset_phase_agent "$d" "$phase"
            success "Reset ${phase} agent for workflow '${workflow}' to default ($(default_phase_agent "$phase"))."
            ;;

        help|--help|-h)
            cat <<'USAGE'
Usage:
  crossagent agents list [--json]
  crossagent agents add <name> --adapter <claude|codex> [--command <cmd>] [--display-name <name>]
  crossagent agents remove <name>
  crossagent agents show [--workflow <name>] [--json]
  crossagent agents assign <plan|review|implement|verify> <agent> [--workflow <name>]
  crossagent agents reset <plan|review|implement|verify> [--workflow <name>]
USAGE
            ;;

        *)
            die "Unknown agents command: ${subcmd}. Run 'crossagent agents help'."
            ;;
    esac
}

cmd_repos() {
    local subcmd="${1:-list}"
    shift 2>/dev/null || true

    case "$subcmd" in
        list)
            local json_mode=false workflow=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --json) json_mode=true; shift ;;
                    --workflow) require_option_arg "$1" "${2:-}"; workflow="$2"; shift 2 ;;
                    -*) die "Unknown option: $1" ;;
                    *) die "Unexpected argument: $1" ;;
                esac
            done

            [[ -n "$workflow" ]] || workflow=$(require_workflow)
            local d="$WORKFLOWS_DIR/$workflow"
            [[ -d "$d" ]] || die "Workflow '${workflow}' not found."

            local repo add_dirs
            repo=$(get_conf "$d" "repo")
            add_dirs=$(get_conf "$d" "add_dirs")

            if $json_mode; then
                cat <<EJSON
{"primary":"$(json_escape "$repo")","additional":$(_json_csv_to_array "$add_dirs")}
EJSON
                return 0
            fi

            echo ""
            echo -e "  ${BOLD}Repositories: ${workflow}${NC}"
            separator
            echo -e "  ${GREEN}*${NC} ${repo} ${DIM}(primary)${NC}"
            if [[ -n "$add_dirs" ]]; then
                local _dirs _dir
                IFS=',' read -ra _dirs <<< "$add_dirs"
                for _dir in "${_dirs[@]}"; do
                    [[ -n "$_dir" ]] && echo -e "    ${_dir}"
                done
            fi
            echo ""
            ;;

        add)
            local path="" workflow=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --workflow) require_option_arg "$1" "${2:-}"; workflow="$2"; shift 2 ;;
                    -*) die "Unknown option: $1" ;;
                    *)  path="$1"; shift ;;
                esac
            done

            [[ -n "$path" ]] || die "Usage: crossagent repos add <path> [--workflow <name>]"
            path=$(resolve_dir "Repository" "$path")

            [[ -n "$workflow" ]] || workflow=$(require_workflow)
            local d="$WORKFLOWS_DIR/$workflow"
            [[ -d "$d" ]] || die "Workflow '${workflow}' not found."

            local repo add_dirs
            repo=$(get_conf "$d" "repo")
            add_dirs=$(get_conf "$d" "add_dirs")

            # Check if it's already the primary repo
            [[ "$path" == "$repo" ]] && die "Path is already the primary repository."

            # Check for duplicate in add_dirs
            if _add_dirs_contains "$add_dirs" "$path"; then
                die "Path is already in the repository list: ${path}"
            fi

            add_dirs=$(_add_dirs_append "$add_dirs" "$path")
            set_conf "$d" "add_dirs" "$add_dirs"
            success "Added repository: ${path}"
            ;;

        remove|rm)
            local path="" workflow=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --workflow) require_option_arg "$1" "${2:-}"; workflow="$2"; shift 2 ;;
                    -*) die "Unknown option: $1" ;;
                    *)  path="$1"; shift ;;
                esac
            done

            [[ -n "$path" ]] || die "Usage: crossagent repos remove <path> [--workflow <name>]"
            # Resolve if the path exists, otherwise try matching raw
            if [[ -d "$path" ]]; then
                path=$(cd "$path" && pwd)
            fi

            [[ -n "$workflow" ]] || workflow=$(require_workflow)
            local d="$WORKFLOWS_DIR/$workflow"
            [[ -d "$d" ]] || die "Workflow '${workflow}' not found."

            local repo add_dirs
            repo=$(get_conf "$d" "repo")
            add_dirs=$(get_conf "$d" "add_dirs")

            # Cannot remove primary repo
            [[ "$path" == "$repo" ]] && die "Cannot remove the primary repository. Use ${BOLD}crossagent repos set-primary${NC} to change it."

            # Check it exists in add_dirs
            if ! _add_dirs_contains "$add_dirs" "$path"; then
                die "Path not found in repository list: ${path}"
            fi

            add_dirs=$(_add_dirs_remove "$add_dirs" "$path")
            set_conf "$d" "add_dirs" "$add_dirs"
            success "Removed repository: ${path}"
            ;;

        set-primary)
            local path="" workflow=""
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --workflow) require_option_arg "$1" "${2:-}"; workflow="$2"; shift 2 ;;
                    -*) die "Unknown option: $1" ;;
                    *)  path="$1"; shift ;;
                esac
            done

            [[ -n "$path" ]] || die "Usage: crossagent repos set-primary <path> [--workflow <name>]"
            path=$(resolve_dir "Repository" "$path")

            [[ -n "$workflow" ]] || workflow=$(require_workflow)
            local d="$WORKFLOWS_DIR/$workflow"
            [[ -d "$d" ]] || die "Workflow '${workflow}' not found."

            local repo add_dirs
            repo=$(get_conf "$d" "repo")
            add_dirs=$(get_conf "$d" "add_dirs")

            # Idempotent: if already primary, nothing to do
            if [[ "$path" == "$repo" ]]; then
                info "Path is already the primary repository."
                return 0
            fi

            # Remove new primary from add_dirs if it was there
            add_dirs=$(_add_dirs_remove "$add_dirs" "$path")

            # Move old primary into add_dirs
            if [[ -n "$repo" ]]; then
                if ! _add_dirs_contains "$add_dirs" "$repo"; then
                    add_dirs=$(_add_dirs_append "$add_dirs" "$repo")
                fi
            fi

            set_conf "$d" "repo" "$path"
            set_conf "$d" "add_dirs" "$add_dirs"
            success "Primary repository changed to: ${path}"
            [[ -n "$repo" ]] && info "Previous primary moved to additional: ${repo}"
            ;;

        help|--help|-h)
            cat <<'USAGE'
Usage:
  crossagent repos list [--json] [--workflow <name>]
  crossagent repos add <path> [--workflow <name>]
  crossagent repos remove <path> [--workflow <name>]
  crossagent repos set-primary <path> [--workflow <name>]
USAGE
            ;;

        *)
            die "Unknown repos command: ${subcmd}. Run 'crossagent repos help'."
            ;;
    esac
}

cmd_phase_cmd() {
    local phase_arg="" json_mode=false force=false impl_phase=1

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)   json_mode=true; shift ;;
            --force)  force=true; shift ;;
            --phase)
                require_option_arg "$1" "${2:-}"
                impl_phase="$2"
                shift 2
                ;;
            -*)       die "Unknown option: $1" ;;
            *)        phase_arg="$1"; shift ;;
        esac
    done

    [[ -z "$phase_arg" ]] && die "Usage: crossagent phase-cmd <plan|review|implement|verify> [--json] [--phase N]"
    [[ "$impl_phase" =~ ^[1-9][0-9]*$ ]] || die "Implementation phase must be a positive integer."

    local name d phase pn
    name=$(require_workflow); d=$(wf_dir "$name"); phase=$(get_phase "$d")
    pn=$(phase_num "$phase")

    local repo add_dirs
    repo=$(get_conf "$d" "repo"); add_dirs=$(get_conf "$d" "add_dirs")

    local tool prompt_file output_file target_phase agent agent_display adapter

    case "$phase_arg" in
        plan)
            target_phase=1
            [[ "$pn" -gt 1 && "$force" == false ]] && die "Plan phase already completed. Use --force to re-run."
            prompt_file=$(gen_plan_prompt "$d")
            output_file="$d/plan.md"
            ;;
        review)
            target_phase=2
            [[ "$pn" -lt 2 ]] && die "Complete Phase 1 first. Run: ${BOLD}crossagent plan${NC}"
            [[ "$pn" -gt 2 && "$force" == false ]] && die "Review phase already completed. Use --force to re-run."
            [[ ! -f "$d/plan.md" ]] && die "Plan file missing: $d/plan.md"
            prompt_file=$(gen_review_prompt "$d")
            output_file="$d/review.md"
            ;;
        implement|impl)
            target_phase=3
            [[ "$pn" -lt 3 ]] && die "Complete Phase 2 first. Run: ${BOLD}crossagent review${NC}"
            [[ "$pn" -gt 4 && "$force" == false ]] && die "Workflow is complete. Use --force to re-run implementation."
            prompt_file=$(gen_implement_prompt "$d" "$impl_phase")
            output_file="$d/implement.md"
            ;;
        verify)
            target_phase=4
            [[ "$pn" -lt 4 ]] && die "Complete Phase 3 first. Run: ${BOLD}crossagent implement${NC}"
            [[ "$pn" -gt 4 && "$force" == false ]] && die "Workflow is complete. Use --force to re-run verification."
            prompt_file=$(gen_verify_prompt "$d")
            output_file="$d/verify.md"
            ;;
        *)
            die "Unknown phase: $phase_arg. Use: plan, review, implement, verify"
            ;;
    esac

    agent=$(get_phase_agent "$d" "$target_phase")
    agent_display=$(get_agent_prop "$agent" "display_name")
    adapter=$(get_agent_prop "$agent" "adapter")
    tool=$(get_agent_prop "$agent" "command")

    # Build the prompt text.
    # Claude reads files natively, so we point it to the prompt file.
    # Codex needs the full prompt content inline (including general instructions)
    # since it may not automatically read files referenced by path.
    local prompt
    if [[ "$adapter" == "codex" ]]; then
        local general_file="$d/prompts/general.md"
        if [[ -f "$general_file" ]]; then
            prompt="$(cat "$general_file")

---

$(cat "$prompt_file")"
        else
            prompt=$(cat "$prompt_file")
        fi
    else
        prompt="Read and follow the instructions at ${prompt_file}"
    fi

    # Build spawn args — include sandbox/auto-accept flags per adapter
    _build_launch_args "$d" "$add_dirs"
    local spawn_args=()
    if [[ "$adapter" == "claude" ]]; then
        local settings_file
        settings_file=$(_gen_sandbox_settings "$d" "$repo" "$add_dirs")
        spawn_args+=(--permission-mode auto --settings "$settings_file")
    elif [[ "$adapter" == "codex" ]]; then
        spawn_args+=(--full-auto -C "$repo")
    fi
    spawn_args+=("${LAUNCH_ARGS[@]}")
    # Use -- to separate options from positional prompt arg.
    # Without this, variadic --add-dir <directories...> swallows the prompt.
    spawn_args+=("--")
    spawn_args+=("$prompt")

    if $json_mode; then
        local args_json="["
        local first=true
        for arg in "${spawn_args[@]}"; do
            $first || args_json+=","
            args_json+="\"$(json_escape "$arg")\""
            first=false
        done
        args_json+="]"

        local out_json="null"
        [[ -n "${output_file:-}" ]] && out_json="\"$(json_escape "$output_file")\""

        cat <<EJSON
{
  "agent": {"name":"$(json_escape "$agent")","display_name":"$(json_escape "$agent_display")","adapter":"$(json_escape "$adapter")"},
  "command": "$(json_escape "$tool")",
  "args": ${args_json},
  "cwd": "$(json_escape "$repo")",
  "prompt": "$(json_escape "$prompt")",
  "prompt_file": "$(json_escape "$prompt_file")",
  "output_file": ${out_json},
  "phase": ${target_phase},
  "phase_label": "$(echo "${PHASE_LABELS[$target_phase]}" | tr '[:upper:]' '[:lower:]')",
  "workflow": "$(json_escape "$name")",
  "workflow_dir": "$(json_escape "$d")"
}
EJSON
    else
        echo "agent: $agent ($agent_display)"
        echo "tool: $tool"
        echo "cwd: $repo"
        echo "prompt: $prompt"
        echo "prompt_file: $prompt_file"
        [[ -n "${output_file:-}" ]] && echo "output_file: $output_file"
        echo "phase: $target_phase (${PHASE_LABELS[$target_phase]})"
        echo "args: ${spawn_args[*]}"
    fi
}

cmd_use() {
    local target="${1:-}"
    [[ -z "$target" ]] && die "Usage: crossagent use <name>"
    [[ ! -d "$WORKFLOWS_DIR/$target" ]] && die "Workflow '${target}' not found. Run ${BOLD}crossagent list${NC}"
    set_current "$target"
    success "Switched to: ${target}"
}

cmd_next() {
    local name d phase
    name=$(require_workflow); d=$(wf_dir "$name"); phase=$(get_phase "$d")

    case "$phase" in
        1)    cmd_plan "$@" ;;
        2)    cmd_review "$@" ;;
        3)    cmd_implement "$@" ;;
        4)    cmd_verify "$@" ;;
        done) success "Workflow '${name}' is already complete." ;;
        *)    die "Unknown phase: $phase" ;;
    esac
}

cmd_advance() {
    local name d phase
    name=$(require_workflow); d=$(wf_dir "$name"); phase=$(get_phase "$d")

    [[ "$phase" == "done" ]] && { warn "Workflow already complete."; return 0; }

    local next=$((phase + 1))
    if [[ $next -gt 4 ]]; then
        set_phase "$d" "done"
        success "Workflow marked complete."
    else
        set_phase "$d" "$next"
        success "Advanced to phase ${next} — ${PHASE_LABELS[$next]}"
    fi
}

cmd_done() {
    local name d
    name=$(require_workflow); d=$(wf_dir "$name")
    set_phase "$d" "done"
    success "Workflow '${name}' marked complete."
}

cmd_revert() {
    local target="" reason="" json_mode=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)     json_mode=true; shift ;;
            --reason)   require_option_arg "$1" "${2:-}"; reason="$2"; shift 2 ;;
            -*)         die "Unknown option: $1" ;;
            *)          target="$1"; shift ;;
        esac
    done

    [[ -z "$target" ]] && die "Usage: crossagent revert <target_phase> [--reason <text>]"
    [[ "$target" =~ ^[1-4]$ ]] || die "Target phase must be 1-4."

    local name d phase pn
    name=$(require_workflow); d=$(wf_dir "$name"); phase=$(get_phase "$d")
    pn=$(phase_num "$phase")

    [[ "$pn" -le "$target" ]] && die "Cannot revert: current phase ($phase) is not ahead of target ($target)."

    # Get retry count and enforce max
    local retry_count max_retries
    retry_count=$(get_conf "$d" "retry_count")
    retry_count=${retry_count:-0}
    max_retries=$(get_conf "$d" "max_retries")
    max_retries=${max_retries:-3}

    if [[ "$retry_count" -ge "$max_retries" ]]; then
        if $json_mode; then
            echo "{\"action\":\"needs_human\",\"reason\":\"Retry limit reached (${retry_count}/${max_retries})\",\"retry_count\":${retry_count},\"max_retries\":${max_retries}}"
            return 0
        fi
        die "Retry limit reached (${retry_count}/${max_retries}). Resolve issues manually."
    fi

    retry_count=$((retry_count + 1))
    local attempt="$retry_count"

    # Archive artifacts from target phase through current phase
    local phase_keys=( '' 'plan' 'review' 'implement' 'verify' )
    local i
    for (( i=target; i<=4; i++ )); do
        local key="${phase_keys[$i]}"
        local artifact="$d/${key}.md"
        if [[ -f "$artifact" ]]; then
            mv "$artifact" "$d/${key}.attempt-${attempt}.md"
        fi
    done

    # Determine the source artifact that triggered the revert.
    # verify.md triggers revert to implement; review.md triggers revert to plan.
    local source_artifact=""
    local source_label=""
    if [[ -f "$d/verify.attempt-${attempt}.md" ]]; then
        source_artifact="$d/verify.attempt-${attempt}.md"
        source_label="verification report"
    elif [[ -f "$d/verify.md" ]]; then
        source_artifact="$d/verify.md"
        source_label="verification report"
    elif [[ -f "$d/review.attempt-${attempt}.md" ]]; then
        source_artifact="$d/review.attempt-${attempt}.md"
        source_label="review feedback"
    elif [[ -f "$d/review.md" ]]; then
        source_artifact="$d/review.md"
        source_label="review feedback"
    fi

    # Extract the specific issues/feedback from the source artifact
    local extracted_issues=""
    if [[ -n "$source_artifact" && -f "$source_artifact" ]]; then
        extracted_issues=$(cat "$source_artifact")
    fi

    # Write revert context with the actual issues inlined
    mkdir -p "$d/prompts"
    local ctx="$d/prompts/revert-context.md"
    cat > "$ctx" <<RCTX
# Revert Context (Attempt ${attempt})

## Why This Phase Is Being Re-run
${reason:-The previous attempt did not pass review/verification.}

## IMPORTANT: Surgical Fix Required
This is a **targeted retry**, NOT a full redo. You must:
1. Read the specific issues listed below
2. Make **only** the changes needed to address those issues
3. Do NOT rewrite or redo work that was already correct
4. Preserve all existing work that is not related to the issues
RCTX

    # Inline the full source artifact content
    if [[ -n "$extracted_issues" ]]; then
        cat >> "$ctx" <<RCTX

## Issues to Address (from ${source_label})
The following is the complete ${source_label} from the previous attempt.
Focus on sections marked as issues, failures, or requiring changes:

---
${extracted_issues}
---
RCTX
    fi

    # List archived files for reference
    local has_archived=false
    for (( i=target; i<=4; i++ )); do
        local key="${phase_keys[$i]}"
        local archived="$d/${key}.attempt-${attempt}.md"
        if [[ -f "$archived" ]]; then
            if ! $has_archived; then
                printf '\n## Previous Attempt Artifacts\n' >> "$ctx"
                has_archived=true
            fi
            echo "- \`${archived}\`" >> "$ctx"
        fi
    done

    cat >> "$ctx" <<RCTX

## Surgical Fix Guidelines
- Identify each specific issue from the ${source_label} above
- For each issue, make the minimum change required to resolve it
- Do NOT refactor, restructure, or rewrite code that was not flagged
- If the ${source_label} mentions specific files and line numbers, go directly to those locations
- After fixing, verify your changes resolve each listed issue
- Document what you fixed and how in your output file
RCTX

    # Update state
    set_phase "$d" "$target"
    set_conf "$d" "retry_count" "$retry_count"

    if $json_mode; then
        cat <<EJSON
{
  "action": "reverted",
  "target_phase": ${target},
  "target_label": "$(echo "${PHASE_LABELS[$target]}" | tr '[:upper:]' '[:lower:]')",
  "attempt": ${attempt},
  "retry_count": ${retry_count},
  "max_retries": ${max_retries},
  "revert_context": "$(json_escape "$ctx")"
}
EJSON
    else
        success "Reverted to phase ${target} — ${PHASE_LABELS[$target]} (attempt ${attempt}/${max_retries})"
        info "Revert context written to: ${ctx}"
    fi
}

cmd_supervise() {
    local json_mode=false supervise_phase=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)  json_mode=true; shift ;;
            --phase) require_option_arg "$1" "${2:-}"; supervise_phase="$2"; shift 2 ;;
            *)       shift ;;
        esac
    done

    local name d phase pn
    name=$(require_workflow); d=$(wf_dir "$name"); phase=$(get_phase "$d")
    pn=$(phase_num "$phase")

    local retry_count max_retries
    retry_count=$(get_conf "$d" "retry_count")
    retry_count=${retry_count:-0}
    max_retries=$(get_conf "$d" "max_retries")
    max_retries=${max_retries:-3}

    # Determine which phase to supervise: explicit --phase or auto-detect
    if [[ -z "$supervise_phase" ]]; then
        # Auto-detect: if verify.md exists, supervise verify; else if review.md, supervise review
        if [[ -f "$d/verify.md" ]]; then
            supervise_phase="verify"
        elif [[ -f "$d/review.md" ]]; then
            supervise_phase="review"
        else
            if $json_mode; then
                echo '{"action":"waiting","reason":"No artifact to supervise"}'
            else
                info "No artifact to supervise."
            fi
            return 0
        fi
    fi

    case "$supervise_phase" in
        verify)
            _supervise_verify "$d" "$json_mode" "$retry_count" "$max_retries"
            ;;
        review)
            _supervise_review "$d" "$json_mode" "$retry_count" "$max_retries"
            ;;
        *)
            if $json_mode; then
                echo "{\"action\":\"pass\",\"reason\":\"No supervision needed for phase: ${supervise_phase}\"}"
            else
                info "No supervision defined for phase: ${supervise_phase}"
            fi
            ;;
    esac
}

_supervise_verify() {
    local d="$1" json_mode="$2" retry_count="$3" max_retries="$4"
    local verify_file="$d/verify.md"

    if [[ ! -f "$verify_file" ]]; then
        if [[ "$json_mode" == true ]]; then
            echo '{"action":"waiting","reason":"verify.md not found"}'
        else
            info "Verify artifact not found."
        fi
        return 0
    fi

    local verdict status rec
    while IFS= read -r line; do
        case "$line" in
            verdict=*) verdict="${line#verdict=}" ;;
            status=*) status="${line#status=}" ;;
            recommendation=*) rec="${line#recommendation=}" ;;
        esac
    done < <(judge_verify "$verify_file")

    case "$verdict" in
        pass)
            set_phase "$d" "done"
            if [[ "$json_mode" == true ]]; then
                echo "{\"action\":\"done\",\"verdict\":\"${verdict}\",\"status\":\"$(json_escape "$status")\",\"recommendation\":\"$(json_escape "$rec")\"}"
            else
                success "Verification passed — workflow complete!"
            fi
            ;;
        fix)
            local reason="Verifier recommendation: ${rec}. Status: ${status}. Surgically fix the issues flagged in verify.md — do NOT re-implement from scratch."
            if [[ "$json_mode" == true ]]; then
                cmd_revert 3 --reason "$reason" --json
            else
                warn "Verification found issues. Reverting to implement for surgical fix."
                cmd_revert 3 --reason "$reason"
            fi
            ;;
        rework)
            local reason="Verifier recommendation: ${rec}. Status: ${status}. The approach needs fundamental rework — revise the plan addressing the verifier's concerns."
            if [[ "$json_mode" == true ]]; then
                cmd_revert 1 --reason "$reason" --json
            else
                warn "Verification requires rework. Reverting to plan."
                cmd_revert 1 --reason "$reason"
            fi
            ;;
        unknown|*)
            if [[ "$json_mode" == true ]]; then
                echo "{\"action\":\"unknown\",\"verdict\":\"${verdict}\",\"status\":\"$(json_escape "$status")\",\"recommendation\":\"$(json_escape "$rec")\",\"retry_count\":${retry_count},\"max_retries\":${max_retries}}"
            else
                warn "Could not determine verdict from verify.md."
                info "Status: ${status}"
                info "Recommendation: ${rec}"
            fi
            ;;
    esac
}

_supervise_review() {
    local d="$1" json_mode="$2" retry_count="$3" max_retries="$4"
    local review_file="$d/review.md"

    if [[ ! -f "$review_file" ]]; then
        if [[ "$json_mode" == true ]]; then
            echo '{"action":"waiting","reason":"review.md not found"}'
        else
            info "Review artifact not found."
        fi
        return 0
    fi

    local verdict review_verdict
    while IFS= read -r line; do
        case "$line" in
            verdict=*) verdict="${line#verdict=}" ;;
            review_verdict=*) review_verdict="${line#review_verdict=}" ;;
        esac
    done < <(judge_review "$review_file")

    case "$verdict" in
        approve)
            # Review approved — proceed normally (no intervention)
            if [[ "$json_mode" == true ]]; then
                echo "{\"action\":\"pass\",\"verdict\":\"${verdict}\",\"review_verdict\":\"$(json_escape "$review_verdict")\"}"
            else
                success "Review approved the plan."
            fi
            ;;
        approve_with_changes)
            # Approved with changes — proceed but plan should incorporate feedback
            # The implement prompt already references review.md, so this is fine
            if [[ "$json_mode" == true ]]; then
                echo "{\"action\":\"pass\",\"verdict\":\"${verdict}\",\"review_verdict\":\"$(json_escape "$review_verdict")\"}"
            else
                success "Review approved with changes. Implementation should address the feedback."
            fi
            ;;
        rework)
            local reason="Reviewer verdict: ${review_verdict}. The reviewer requests the plan be reworked. Surgically update the plan addressing the specific issues raised in review.md — do NOT rewrite the entire plan from scratch."
            if [[ "$json_mode" == true ]]; then
                cmd_revert 1 --reason "$reason" --json
            else
                warn "Review requests rework. Reverting to plan for surgical update."
                cmd_revert 1 --reason "$reason"
            fi
            ;;
        unknown|*)
            if [[ "$json_mode" == true ]]; then
                echo "{\"action\":\"unknown\",\"verdict\":\"${verdict}\",\"review_verdict\":\"$(json_escape "$review_verdict")\",\"retry_count\":${retry_count},\"max_retries\":${max_retries}}"
            else
                warn "Could not determine verdict from review.md."
                info "Verdict: ${review_verdict}"
            fi
            ;;
    esac
}

cmd_open() {
    local name d
    name=$(require_workflow); d=$(wf_dir "$name")
    if command -v open >/dev/null 2>&1; then
        open "$d"
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$d"
    else
        die "No supported opener found. Install 'xdg-open' or open the directory manually: $d"
    fi
}

cmd_memory() {
    local subcmd="${1:-show}"
    shift 2>/dev/null || true

    local global_flag=false json_mode=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --global)  global_flag=true; shift ;;
            --json)    json_mode=true; shift ;;
            -h|--help) echo "Usage: crossagent memory [show|list] [--global] [--json]"; exit 0 ;;
            *)         shift ;;
        esac
    done

    ensure_dirs

    case "$subcmd" in
        show)
            if $global_flag; then
                if $json_mode; then
                    local gc_content="" ll_content=""
                    [[ -f "$MEMORY_DIR/global-context.md" ]] && gc_content=$(cat "$MEMORY_DIR/global-context.md")
                    [[ -f "$MEMORY_DIR/lessons-learned.md" ]] && ll_content=$(cat "$MEMORY_DIR/lessons-learned.md")
                    printf '{"type":"global","files":{"global-context.md":{"path":"%s","content":"%s"},"lessons-learned.md":{"path":"%s","content":"%s"}}}' \
                        "$(json_escape "$MEMORY_DIR/global-context.md")" "$(json_escape "$gc_content")" \
                        "$(json_escape "$MEMORY_DIR/lessons-learned.md")" "$(json_escape "$ll_content")"
                    echo ""
                else
                    echo ""
                    echo -e "  ${BOLD}Global Memory${NC}"
                    separator
                    for f in "$MEMORY_DIR"/*.md; do
                        [[ -f "$f" ]] || continue
                        echo ""
                        echo -e "  ${BOLD}$(basename "$f")${NC}"
                        echo -e "  ${DIM}${f}${NC}"
                        echo ""
                        sed 's/^/    /' "$f"
                        echo ""
                        separator
                    done
                    echo ""
                fi
            else
                local name d
                name=$(require_workflow); d=$(wf_dir "$name")
                local mem_path="$d/memory.md"
                if $json_mode; then
                    if [[ -f "$mem_path" ]]; then
                        local content
                        content=$(cat "$mem_path")
                        printf '{"type":"workflow","name":"%s","path":"%s","content":"%s"}' \
                            "$(json_escape "$name")" "$(json_escape "$mem_path")" "$(json_escape "$content")"
                    else
                        printf '{"type":"workflow","name":"%s","path":"%s","content":null}' \
                            "$(json_escape "$name")" "$(json_escape "$mem_path")"
                    fi
                    echo ""
                else
                    echo ""
                    echo -e "  ${BOLD}Workflow Memory: ${name}${NC}"
                    separator
                    if [[ -f "$mem_path" ]]; then
                        echo ""
                        sed 's/^/    /' "$mem_path"
                        echo ""
                    else
                        echo -e "  ${DIM}No memory file yet.${NC}"
                    fi
                    echo ""
                fi
            fi
            ;;
        list)
            if $global_flag; then
                if $json_mode; then
                    local files="[" first=true
                    for f in "$MEMORY_DIR"/*.md; do
                        [[ -f "$f" ]] || continue
                        $first || files+=","
                        local lines
                        lines=$(wc -l < "$f" | tr -d ' ')
                        files+="$(printf '{"name":"%s","path":"%s","lines":%s}' "$(json_escape "$(basename "$f")")" "$(json_escape "$f")" "$lines")"
                        first=false
                    done
                    files+="]"
                    echo "{\"type\":\"global\",\"files\":${files}}"
                else
                    echo ""
                    echo -e "  ${BOLD}Global Memory Files${NC}"
                    separator
                    for f in "$MEMORY_DIR"/*.md; do
                        [[ -f "$f" ]] || { echo -e "  ${DIM}(none)${NC}"; break; }
                        local lines
                        lines=$(wc -l < "$f" | tr -d ' ')
                        echo -e "  $(basename "$f")  ${DIM}(${lines} lines)${NC}"
                    done
                    echo ""
                fi
            else
                local name d
                name=$(require_workflow); d=$(wf_dir "$name")
                if $json_mode; then
                    local files="[" first=true
                    if [[ -f "$d/memory.md" ]]; then
                        local lines
                        lines=$(wc -l < "$d/memory.md" | tr -d ' ')
                        files+="$(printf '{"name":"memory.md","path":"%s","lines":%s}' "$(json_escape "$d/memory.md")" "$lines")"
                        first=false
                    fi
                    files+="]"
                    printf '{"type":"workflow","name":"%s","files":%s}' "$(json_escape "$name")" "$files"
                    echo ""
                else
                    echo ""
                    echo -e "  ${BOLD}Memory Files: ${name}${NC}"
                    separator
                    if [[ -f "$d/memory.md" ]]; then
                        local lines
                        lines=$(wc -l < "$d/memory.md" | tr -d ' ')
                        echo -e "  memory.md  ${DIM}(${lines} lines)${NC}"
                    else
                        echo -e "  ${DIM}(none)${NC}"
                    fi
                    echo ""
                fi
            fi
            ;;
        edit)
            if $global_flag; then
                "${EDITOR:-vi}" "$MEMORY_DIR/global-context.md"
            else
                local name d
                name=$(require_workflow); d=$(wf_dir "$name")
                [[ -f "$d/memory.md" ]] || die "No memory file for workflow '${name}'."
                "${EDITOR:-vi}" "$d/memory.md"
            fi
            ;;
        *)
            die "Unknown memory command: ${subcmd}. Use: show, list, edit"
            ;;
    esac
}

cmd_log() {
    local name d
    name=$(require_workflow); d=$(wf_dir "$name")

    echo ""
    echo -e "  ${BOLD}Artifacts: ${name}${NC}"
    separator

    local found=false
    for artifact in plan.md review.md verify.md; do
        local path="$d/$artifact"
        if [[ -f "$path" ]]; then
            found=true
            echo ""
            echo -e "  ${BOLD}${artifact}${NC}"
            echo -e "  ${DIM}${path}${NC}"
            echo ""
            sed 's/^/    /' "$path"
            echo ""
            separator
        fi
    done

    $found || echo -e "  ${DIM}No artifacts yet.${NC}"
    echo ""
}

cmd_reset() {
    local target="${1:-}"
    [[ -z "$target" ]] && die "Usage: crossagent reset <name>"
    local d="$WORKFLOWS_DIR/$target"
    [[ ! -d "$d" ]] && die "Workflow '${target}' not found."

    echo -ne "  Reset workflow '${target}'? All artifacts will be deleted. [y/N] "
    read -r confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || { echo "  Cancelled."; return 0; }

    rm -rf "$d"
    local current
    current=$(get_current)
    [[ "$current" == "$target" ]] && rm -f "$CROSSAGENT_HOME/current"

    success "Workflow '${target}' deleted."
}

# ── Usage ───────────────────────────────────────────────────────────────────

usage() {
    cat <<'USAGE'

  crossagent — Cross-Model AI Agent Orchestrator v1.0.0

  WORKFLOW COMMANDS
    new <name> [opts]     Create a new workflow
      --repo <path>         Target repository (default: cwd)
      --add-dir <path>      Additional repo directories (repeatable)

    plan [--force]        Phase 1: Plan with Claude Code
    review [--force]      Phase 2: Review plan with Codex CLI
    implement [opts]      Phase 3: Implement with Claude Code
      --phase <n>           Implementation sub-phase (default: 1)
    verify [--force]      Phase 4: Verify with Codex CLI

  NAVIGATION
    next                  Run the next pending phase
    status                Show current workflow state
    list                  List all workflows
    use <name>            Switch active workflow
    advance               Manually advance to next phase
    done                  Mark workflow as complete

  REPOSITORIES
    repos list            List repositories for active workflow
    repos add <path>      Add an additional repository
    repos remove <path>   Remove an additional repository
    repos set-primary     Change the primary repository (cwd)

  AGENTS
    agents list           List builtin and custom static agents
    agents add            Register a custom static agent
    agents remove         Remove a custom static agent
    agents show           Show per-phase agent assignments
    agents assign         Assign an agent to a workflow phase
    agents reset          Reset a workflow phase to its default agent

  INTEGRATION (for UI companion / scripting)
    status --json         Machine-readable workflow state
    list --json           Machine-readable workflow list
    phase-cmd <phase>     Get launch parameters for a phase (does not spawn)
      --json                JSON output (default: plain text)
      --force               Allow launch config for already-completed phases
      --phase <n>           Sub-phase for implement (default: 1)

  MEMORY
    memory show           Show workflow memory (default)
    memory show --global  Show global memory files
    memory list           List memory files for current workflow
    memory list --global  List global memory files
    memory edit           Edit workflow memory in $EDITOR
    memory edit --global  Edit global context in $EDITOR
      --json              JSON output for show/list

  UTILITIES
    log                   Display all artifacts (plan, review, report)
    open                  Open workflow directory in Finder
    reset <name>          Delete a workflow and its artifacts
    help                  Show this help
    version               Show version

  WORKFLOW
    ┌────────┐  plan.md  ┌────────┐  review.md  ┌────────┐  changes  ┌────────┐
    │ 1.PLAN ├──────────►│2.REVIEW├────────────►│3.IMPL  ├─────────►│4.VERIFY│
    │ Claude │           │ Codex  │             │ Claude │          │ Codex  │
    └────────┘           └────────┘             └────────┘          └────────┘

  EXAMPLES
    crossagent new auth-refactor --repo ~/projects/api
    crossagent new cache-layer --repo ~/proj/svc --add-dir ~/proj/shared
    crossagent repos list
    crossagent repos add ~/projects/shared-lib
    crossagent repos set-primary ~/projects/api-v2
    crossagent agents add reviewer-alt --adapter codex --command codex
    crossagent agents assign review reviewer-alt
    crossagent plan
    crossagent review
    crossagent implement --phase 1
    crossagent implement --phase 2
    crossagent verify

USAGE
}

# ── Main ────────────────────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        new)             cmd_new "$@" ;;
        plan)            cmd_plan "$@" ;;
        review)          cmd_review "$@" ;;
        implement|impl)  cmd_implement "$@" ;;
        verify)          cmd_verify "$@" ;;
        status|st)       cmd_status "$@" ;;
        list|ls)         cmd_list "$@" ;;
        agents|agent)    cmd_agents "$@" ;;
        repos)           cmd_repos "$@" ;;
        phase-cmd)       cmd_phase_cmd "$@" ;;
        use)             cmd_use "$@" ;;
        next)            cmd_next "$@" ;;
        advance)         cmd_advance "$@" ;;
        revert)          cmd_revert "$@" ;;
        supervise)       cmd_supervise "$@" ;;
        done)            cmd_done "$@" ;;
        open)            cmd_open "$@" ;;
        memory|mem)      cmd_memory "$@" ;;
        log)             cmd_log "$@" ;;
        reset)           cmd_reset "$@" ;;
        help|--help|-h)  usage ;;
        version|--version|-v) echo "crossagent ${CROSSAGENT_VERSION}" ;;
        *)               die "Unknown command: ${cmd}. Run 'crossagent help'." ;;
    esac
}

main "$@"
