get_current()     { [[ -f "$CROSSAGENT_HOME/current" ]] && cat "$CROSSAGENT_HOME/current" || echo ""; }
set_current()     { echo "$1" > "$CROSSAGENT_HOME/current"; }
wf_dir()          { echo "$WORKFLOWS_DIR/${1:-$(get_current)}"; }
get_phase()       { [[ -f "$1/phase" ]] && cat "$1/phase" || echo "0"; }
set_phase()       { echo "$2" > "$1/phase"; }
get_description() { [[ -f "$1/description" ]] && cat "$1/description" || echo ""; }

get_conf() {
    local file="$1/config" key="$2"
    [[ -f "$file" ]] && grep "^${key}=" "$file" 2>/dev/null | cut -d= -f2- || echo ""
}

set_conf() {
    local file="$1/config" key="$2" val="$3"
    local tmp="${file}.tmp.$$" found=false line

    : > "$tmp"

    if [[ -f "$file" ]]; then
        while IFS= read -r line || [[ -n "$line" ]]; do
            if [[ "$line" == "${key}="* ]]; then
                printf '%s=%s\n' "$key" "$val" >> "$tmp"
                found=true
            else
                printf '%s\n' "$line" >> "$tmp"
            fi
        done < "$file"
    fi

    if [[ "$found" == false ]]; then
        printf '%s=%s\n' "$key" "$val" >> "$tmp"
    fi

    mv "$tmp" "$file"
}

require_workflow() {
    local name
    name=$(get_current)
    [[ -z "$name" ]] && die "No active workflow. Run: ${BOLD}crossagent new <name>${NC}"
    local d
    d=$(wf_dir "$name")
    [[ ! -d "$d" ]] && die "Workflow dir missing: $d"
    echo "$name"
}

# ── Dependency Check ────────────────────────────────────────────────────────

# Convert phase to number for safe arithmetic (done → 5)
phase_num() { [[ "$1" == "done" ]] && echo 5 || echo "$1"; }

require_option_arg() {
    local option="$1" value="${2:-}"
    [[ -n "$value" ]] || die "Option requires a value: ${option}"
}

resolve_dir() {
    local label="$1" path="$2"
    [[ -n "$path" ]] || die "${label} path cannot be empty."
    [[ "$path" != *,* ]] || die "${label} path cannot contain commas: ${path}"
    [[ -d "$path" ]] || die "${label} path not found: ${path}"
    (cd "$path" && pwd)
}

phase_key() {
    case "$1" in
        1|plan) echo "plan" ;;
        2|review) echo "review" ;;
        3|implement|impl) echo "implement" ;;
        4|verify) echo "verify" ;;
        *) return 1 ;;
    esac
}

phase_id() {
    case "$1" in
        1|plan) echo 1 ;;
        2|review) echo 2 ;;
        3|implement|impl) echo 3 ;;
        4|verify) echo 4 ;;
        *) return 1 ;;
    esac
}

phase_agent_conf_key() {
    local key
    key=$(phase_key "$1") || return 1
    echo "${key}_agent"
}

default_phase_agent() {
    case "$(phase_key "$1")" in
        plan|implement) echo "claude" ;;
        review|verify) echo "codex" ;;
    esac
}

agent_is_builtin() {
    [[ "$1" == "claude" || "$1" == "codex" ]]
}

agent_file() {
    echo "$AGENTS_DIR/$1"
}

agent_exists() {
    local name="$1"
    agent_is_builtin "$name" || [[ -f "$(agent_file "$name")" ]]
}

get_agent_prop() {
    local name="$1" key="$2" file
    if agent_is_builtin "$name"; then
        case "$name:$key" in
            claude:adapter) echo "claude" ;;
            claude:command) echo "claude" ;;
            claude:display_name) echo "Claude Code" ;;
            codex:adapter) echo "codex" ;;
            codex:command) echo "codex" ;;
            codex:display_name) echo "OpenAI Codex" ;;
            *) echo "" ;;
        esac
        return 0
    fi

    file=$(agent_file "$name")
    [[ -f "$file" ]] && grep "^${key}=" "$file" 2>/dev/null | cut -d= -f2- || echo ""
}

require_agent() {
    local name="$1"
    agent_exists "$name" || die "Agent not found: ${name}"
}

sanitize_agent_name() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]//g'
}

require_agent_command() {
    local agent="$1" cmd
    cmd=$(get_agent_prop "$agent" "command")
    [[ -n "$cmd" ]] || die "Agent '${agent}' has no command configured."
    if [[ "$cmd" == */* ]]; then
        [[ -x "$cmd" ]] || die "Agent '${agent}' command is not executable: ${cmd}"
    else
        command -v "$cmd" >/dev/null 2>&1 || die "Agent '${agent}' command not found on PATH: ${cmd}"
    fi
}

get_phase_agent() {
    local d="$1" phase="$2" key value
    key=$(phase_agent_conf_key "$phase") || die "Unknown phase: ${phase}"
    value=$(get_conf "$d" "$key")
    if [[ -n "$value" ]]; then
        echo "$value"
    else
        default_phase_agent "$phase"
    fi
}

set_phase_agent() {
    local d="$1" phase="$2" agent="$3" key
    require_agent "$agent"
    key=$(phase_agent_conf_key "$phase") || die "Unknown phase: ${phase}"
    set_conf "$d" "$key" "$agent"
}

reset_phase_agent() {
    local d="$1" phase="$2"
    set_phase_agent "$d" "$phase" "$(default_phase_agent "$phase")"
}

phase_tool_name() {
    local d="$1" phase="$2" agent
    agent=$(get_phase_agent "$d" "$phase")
    get_agent_prop "$agent" "display_name"
}

# ── JSON Helpers (for --json output & UI integration) ─────────────────────

json_escape() {
    local s="$1"
    s=${s//\\/\\\\}
    s=${s//\"/\\\"}
    s=${s//$'\n'/\\n}
    s=${s//$'\t'/\\t}
    s=${s//$'\r'/\\r}
    printf '%s' "$s"
}

# ── Multi-Repo Helpers ─────────────────────────────────────────────────────

# Check if a path is in a comma-separated list (exact match on resolved paths)
_add_dirs_contains() {
    local csv="$1" needle="$2"
    [[ -z "$csv" ]] && return 1
    local _dirs _dir
    IFS=',' read -ra _dirs <<< "$csv"
    for _dir in "${_dirs[@]}"; do
        [[ "$_dir" == "$needle" ]] && return 0
    done
    return 1
}

# Append a path to a comma-separated list (no dedup check — caller must check)
_add_dirs_append() {
    local csv="$1" path="$2"
    if [[ -z "$csv" ]]; then
        echo "$path"
    else
        echo "${csv},${path}"
    fi
}

# Remove a path from a comma-separated list; returns new CSV
_add_dirs_remove() {
    local csv="$1" needle="$2"
    [[ -z "$csv" ]] && { echo ""; return; }
    local _dirs _dir out="" first=true
    IFS=',' read -ra _dirs <<< "$csv"
    for _dir in "${_dirs[@]}"; do
        [[ "$_dir" == "$needle" ]] && continue
        [[ -z "$_dir" ]] && continue
        $first || out+=","
        out+="$_dir"
        first=false
    done
    echo "$out"
}

_json_csv_to_array() {
    local csv="$1"
    if [[ -z "$csv" ]]; then echo "[]"; return; fi
    local out="[" first=true
    IFS=',' read -ra items <<< "$csv"
    for item in "${items[@]}"; do
        [[ -z "$item" ]] && continue
        $first || out+=","
        out+="\"$(json_escape "$item")\""
        first=false
    done
    echo "${out}]"
}

_json_artifact() {
    local path="$1"
    if [[ -f "$path" ]]; then
        local lines
        lines=$(wc -l < "$path" | tr -d ' ')
        printf '{"exists":true,"path":"%s","lines":%s}' "$(json_escape "$path")" "$lines"
    else
        printf '{"exists":false,"path":"%s"}' "$(json_escape "$path")"
    fi
}

# ── CLI Construction ────────────────────────────────────────────────────────

# Generate sandbox settings JSON for Claude sessions.
# Grants write access to the workflow dir, repo, and any additional dirs
# via sandbox.filesystem.allowWrite so the agent can modify files without
# permission prompts.
_gen_sandbox_settings() {
    local wf_dir=$1 repo=$2 add_dirs=${3:-}
    local settings_file="$wf_dir/prompts/.sandbox-settings.json"

    # Build allowWrite array: workflow dir + repo + global memory dir + additional dirs
    # Paths use // prefix for absolute paths per Claude sandbox convention
    local allow_write="\"/${wf_dir}\",\"/${repo}\",\"/${MEMORY_DIR}\""
    if [[ -n "$add_dirs" ]]; then
        local _dirs _dir
        IFS=',' read -ra _dirs <<< "$add_dirs"
        for _dir in "${_dirs[@]}"; do
            [[ -n "$_dir" ]] && allow_write+=",\"/${_dir}\""
        done
    fi

    mkdir -p "$wf_dir/prompts"
    cat > "$settings_file" <<SETTINGS_EOF
{
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [${allow_write}]
    }
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)"
    ]
  }
}
SETTINGS_EOF
    echo "$settings_file"
}

# Build --add-dir args into global LAUNCH_ARGS array (avoids bash 3.2 nameref issues)
_build_launch_args() {
    local wf_dir=$1 add_dirs=$2
    LAUNCH_ARGS=(--add-dir "$wf_dir" --add-dir "$MEMORY_DIR")
    if [[ -n "$add_dirs" ]]; then
        local _dirs _dir
        IFS=',' read -ra _dirs <<< "$add_dirs"
        for _dir in "${_dirs[@]}"; do
            [[ -n "$_dir" ]] && LAUNCH_ARGS+=(--add-dir "$_dir")
        done
    fi
}

launch_agent() {
    local agent=$1 repo=$2 prompt_file=$3 wf_dir=$4 add_dirs=${5:-}
    local adapter command display prompt

    adapter=$(get_agent_prop "$agent" "adapter")
    command=$(get_agent_prop "$agent" "command")
    display=$(get_agent_prop "$agent" "display_name")

    # Claude reads files natively, so point it to the prompt file.
    # Codex needs the full prompt content inline (including general instructions).
    if [[ "$adapter" == "codex" ]]; then
        local general_file="$wf_dir/prompts/general.md"
        if [[ -f "$general_file" ]]; then
            prompt="$(cat "$general_file")

---

$(cat "$prompt_file")"
        else
            prompt=$(cat "$prompt_file")
        fi
    else
        prompt="Read and follow the instructions at ${prompt_file}"
    fi

    require_agent_command "$agent"

    local repo
    repo=$(get_conf "$wf_dir" "repo")
    _build_launch_args "$wf_dir" "$add_dirs"

    echo -e "  ${DIM}Launching ${display} in ${repo}${NC}"
    echo -e "  ${DIM}Exit the session when done${NC}"
    echo ""

    case "$adapter" in
        claude)
            local settings_file
            settings_file=$(_gen_sandbox_settings "$wf_dir" "$repo" "$add_dirs")
            (cd "$repo" && "$command" --permission-mode auto --settings "$settings_file" "${LAUNCH_ARGS[@]}" -- "$prompt") || true
            ;;
        codex)
            "$command" --full-auto -C "$repo" "${LAUNCH_ARGS[@]}" -- "$prompt" || true
            ;;
        *)
            die "Unsupported agent adapter '${adapter}' for agent '${agent}'"
            ;;
    esac
}

# ── Prompt Generation ───────────────────────────────────────────────────────

gen_general_instructions() {
    local d=$1
    local desc repo add_dirs
    desc=$(get_description "$d")
    repo=$(get_conf "$d" "repo")
    add_dirs=$(get_conf "$d" "add_dirs")

    mkdir -p "$d/prompts"

    # ── Static instructions (no variable interpolation) ──
    cat > "$d/prompts/general.md" <<'GENERAL_EOF'
# Crossagent — General Instructions

These instructions apply to **every phase** of the Crossagent workflow.
Read and absorb them before proceeding with your phase-specific task.

---

## 1. Output File Gate

Before doing any work, check whether your phase's output file already exists:

| Phase     | Output file      |
|-----------|------------------|
| Plan      | `plan.md`        |
| Review    | `review.md`      |
| Implement | `implement.md`   |
| Verify    | `verify.md`      |

**If the output file for your current phase already exists and contains
substantive content, SKIP this phase entirely.** Simply respond:
"Output file already exists — skipping this phase." and exit.

This prevents duplicate work when a phase is re-run after completion.
If the `--force` flag context is mentioned in your phase prompt, ignore
this gate and proceed regardless.

## 2. Execution Mode

You are running in **sandboxed auto-accept mode**. This means:

- All file edits and shell commands within the sandbox boundaries are
  automatically approved — you will NOT be prompted for permission
- The **workflow directory** (where artifacts like `plan.md`, `review.md`,
  etc. live) has been granted write access via sandbox settings — read
  and write freely without permission prompts
- The **repository directory** and any additional directories are also
  in your allowed workspace — explore and modify code as needed
- The sandbox enforces filesystem boundaries: you can only write to
  directories explicitly granted in the sandbox configuration
- Despite auto-accept, exercise good judgment: do not run destructive
  commands (e.g., `rm -rf /`, `git push --force`) unless explicitly
  required by the task
- Focus on completing your phase efficiently without unnecessary pauses

## 3. Workflow Context

You are one agent in a multi-phase, multi-model workflow:
1. **Plan** — create a structured implementation plan
2. **Review** — critically review the plan against the codebase
3. **Implement** — execute the reviewed plan
4. **Verify** — independently verify the implementation

Each phase is handled by a potentially different AI model. Write your
output so that a different model (with no shared memory) can pick up
where you left off. Be explicit, reference file paths, and avoid
ambiguous pronouns like "the function" without naming it.

## 4. File & Path Conventions

- All workflow artifacts live in the workflow directory (provided via
  `--add-dir`). Reference files by their full absolute path.
- Write output files to the **exact path** specified in your phase
  prompt. The orchestrator detects phase completion by checking for
  these files.
- Do NOT rename, move, or delete other phase artifacts (plan.md,
  review.md, implement.md, verify.md).
- **Memory files are shared metadata** — all phase agents may read
  and update \`memory.md\` (workflow) and files under
  \`~/.crossagent/memory/\` (global). See the Memory System section below.

## 5. Communication Style

- Be precise and actionable — avoid vague statements
- Use markdown formatting consistently
- When referencing code, include file paths and line numbers
- When listing changes, group by file
- Keep output concise but complete

## 6. Error Handling

- If you encounter an error that blocks your phase, document it clearly
  in your output file with a `## Blocked` section explaining what went
  wrong and what the user needs to do
- Still write the output file even if the phase could not fully complete —
  this allows the workflow to advance and the user to see what happened
- Never silently fail; always leave a written trace

## 7. Codebase Respect

- Follow existing code conventions, naming patterns, and project structure
- Read relevant existing code before making changes or recommendations
- Do not introduce unnecessary dependencies
- Do not refactor code outside the scope of the current task
## 8. Memory System

Crossagent maintains a persistent memory system to accumulate knowledge
across phases and workflows:

- **Workflow memory** (\`memory.md\` in the workflow directory) — tracks
  decisions, findings, and session notes for this specific workflow.
  All phase agents should update this after completing their work.
- **Global memory** (\`~/.crossagent/memory/\`) — captures cross-workflow
  patterns, conventions, and lessons learned. Update only when you
  discover genuinely reusable knowledge.

Memory files are provided via \`--add-dir\` and sandbox settings.
Your phase prompt includes specific memory update instructions.
GENERAL_EOF

    # ── Dynamic section: workspace directories (interpolated) ──
    cat >> "$d/prompts/general.md" <<DIRS_EOF

## 9. Workspace Directories

**IMPORTANT: At the very start of your session, before doing any other
work, register ALL workspace directories listed below.**

For **Claude Code**, run the \`/add-dir\` slash command for each directory:
\`\`\`
/add-dir ${d}
/add-dir ${repo}
/add-dir ${MEMORY_DIR}
DIRS_EOF

    # Append each additional directory
    if [[ -n "$add_dirs" ]]; then
        local _dirs _dir
        IFS=',' read -ra _dirs <<< "$add_dirs"
        for _dir in "${_dirs[@]}"; do
            [[ -n "$_dir" ]] && echo "/add-dir ${_dir}" >> "$d/prompts/general.md"
        done
    fi

    cat >> "$d/prompts/general.md" <<'DIRS_TAIL'
```

For **Codex CLI**, these directories are already passed via `-C` and
`--add-dir` CLI flags. No additional action is needed.

This ensures you have full read/write access to:
DIRS_TAIL

    # List the directories with descriptions
    cat >> "$d/prompts/general.md" <<DIRS_LIST
- **Workflow directory**: \`${d}\` — where phase artifacts (plan.md, review.md, etc.) live
- **Primary repository**: \`${repo}\` — the main codebase
- **Global memory**: \`${MEMORY_DIR}\` — cross-workflow patterns and lessons learned
DIRS_LIST

    if [[ -n "$add_dirs" ]]; then
        local _dirs _dir
        IFS=',' read -ra _dirs <<< "$add_dirs"
        for _dir in "${_dirs[@]}"; do
            [[ -n "$_dir" ]] && echo "- **Additional directory**: \`${_dir}\`" >> "$d/prompts/general.md"
        done
    fi

    cat >> "$d/prompts/general.md" <<'DIRS_END'

Without registering these directories, you may encounter permission
errors when trying to read or modify files outside your initial
working directory. Always register them first.
DIRS_END

    echo "$d/prompts/general.md"
}

gen_memory_context() {
    local d=$1
    local mem_dir="$CROSSAGENT_HOME/memory"
    local ctx=""

    # Include workflow memory if it exists and has content
    if [[ -f "$d/memory.md" ]]; then
        ctx+="## Workflow Memory

The following is accumulated context from this workflow. Use it to inform
your work and update it with new learnings when done.

<workflow-memory>
$(cat "$d/memory.md")
</workflow-memory>

"
    fi

    # Include global context if it has been edited beyond the default template
    # (check for Changelog entries — default template has an empty table)
    if [[ -f "$mem_dir/global-context.md" ]]; then
        local has_entries
        has_entries=$(grep -c '^|[^-]' "$mem_dir/global-context.md" 2>/dev/null || true)
        # Default template has exactly 1 header row in the table; >1 means real entries exist
        if [[ "$has_entries" -gt 1 ]]; then
            ctx+="## Global Context

The following is accumulated knowledge from previous workflows on this
and other projects. Reference it for patterns and conventions.

<global-context>
$(cat "$mem_dir/global-context.md")
</global-context>

"
        fi
    fi

    printf '%s' "$ctx"
}

gen_memory_update_instructions() {
    local d=$1 phase_name=$2
    local mem_dir="$CROSSAGENT_HOME/memory"
    cat <<EOF

## Memory Update Instructions

After completing your ${phase_name} work, update the memory files:

### Workflow Memory (REQUIRED)
Update \`${d}/memory.md\` with:
- Decisions made during this phase (add to Decisions Log table)
- Key findings or discoveries (add to Key Findings)
- Session notes summarizing what was done

### Global Context (IF new patterns discovered)
If you discovered reusable patterns, conventions, or pitfalls that would
benefit future workflows, append them to:
\`${mem_dir}/global-context.md\`

Only add genuinely new, reusable knowledge — not workflow-specific details.
Add a Changelog entry with today's date and the source workflow name.

### Lessons Learned (IF issues encountered)
If you encountered process issues, rework, or discovered improvements to
how Crossagent workflows should be run, append to:
\`${mem_dir}/lessons-learned.md\`
EOF
}

gen_plan_prompt() {
    local d=$1
    local desc plan_path desc_path general_path
    desc=$(get_description "$d")
    plan_path="$d/plan.md"
    desc_path="$d/description"
    general_path=$(gen_general_instructions "$d")

    mkdir -p "$d/prompts"
    cat > "$d/prompts/plan.md" <<EOF
> **Before starting, read the general instructions at:**
> \`${general_path}\`

# Crossagent Phase 1: Create Implementation Plan

## Your Role
You are the **Planner** in a dual-model AI workflow. Your plan will be
reviewed by a second AI model before implementation begins.

## Feature Request
${desc}

(Full description file: \`${desc_path}\`)

## Step 1: Understand the Request
Before planning, make sure you fully understand what is being asked.

- Read the feature request above carefully
- Explore the codebase to understand the current architecture, patterns,
  and conventions
- If any of the following are unclear, **ask the user before proceeding**:
  - The scope of the change (what is in/out of scope)
  - Expected behavior or acceptance criteria
  - Constraints (backward compatibility, performance, dependencies)
  - Which parts of the codebase are relevant
- Keep your questions concise and grouped — ask once, not piecemeal
- Once you have enough clarity, proceed to Step 2

## Step 2: Write the Plan
